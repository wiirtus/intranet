      <Value Source="RunTime" />
      <Value Source="DBNull" />
    </Parameter>
    <Parameter Name="ParamTo" Type="SmallDateTime">
      <Value Source="RunTime" />
      <Value Source="DBNull" />
    </Parameter>
  </Command>
  </Result>
  
  <Result Name="DocTrLoa" Description="Document Transfer - Loan.">
  <Command Type="Text" Timeout="90">
    <Text><![CDATA[
--DECLARE @UserConId int, @ParamCode varchar(255), @ParamFrom smalldatetime, @ParamTo smalldatetime SELECT @UserConId = 49916, @ParamCode = NULL, @ParamFrom = '2016-01-01', @ParamTo = '2016-09-09'
SET NOCOUNT ON
DECLARE @Sql nvarchar(max)
SET @Sql = ''
IF NOT @ParamCode IS NULL SET @Sql = @Sql + ' AND RTRIM(LTRIM(LoaCode)) = @ParamCode'
IF NOT @ParamFrom IS NULL SET @Sql = @Sql + ' AND LoaC >= @ParamFrom'
IF NOT @ParamTo IS NULL SET @Sql = @Sql + ' AND LoaC <= @ParamTo'
IF @Sql = '' SET @Sql = @Sql + ' AND LoaC >= CONVERT(smalldatetime, CONVERT(char(10), (GETDATE() - 1), 120))'
SET @Sql = 'SELECT /*SCHEMA TOP 0 SCHEMA*/LoaId FROM Loan WITH(NOLOCK) WHERE LoaComId = (SELECT ConComId FROM Contact WITH(NOLOCK) WHERE ConId = @UserConId) AND LoaState = 1' + @Sql --Zatim jen potvrzene

CREATE TABLE #IdList(Id int PRIMARY KEY)
INSERT INTO #IdList
EXEC sp_executesql @Sql, N'@UserConId int, @ParamCode varchar(255), @ParamFrom smalldatetime, @ParamTo smalldatetime', @UserConId, @ParamCode, @ParamFrom, @ParamTo

SELECT LoaId AS [@Id], LoaCode AS [@Code], CASE WHEN LoaCodeO <> '' THEN LoaCodeO END AS [@CodeO], LoaCompl AS [@Compl], LoaDateF AS [@DateF], LoaDateTE AS [@DateTE], CASE WHEN LoaCodeO <> '' THEN LoaNote END AS [@Note],
  DemId AS [@DemId], DemName AS [@DemName],
  (
    SELECT OrdId AS [@Id], OrdCode AS [@Code], CASE WHEN OrdCodeO <> '' THEN OrdCodeO END AS [@CodeO], OrdC AS [@C],
    (
      SELECT OriId AS [@Id], OriQty - OriCanc AS [@Qty], OriPrc AS [@Prc], OriPrcCur AS [@PrcCur], RTRIM(UsdCur.UsdCodeE) AS [@CurCode],
        StiId AS [@StiId], StiCode AS [@StiCode],
        CASE WHEN StiCode2 <> '' THEN StiCode2 END AS [@StiCode2],
        CASE WHEN StiPartNo <> '' THEN StiPartNo END AS [@StiPartNo],
        CASE WHEN StiPartNo2 <> '' THEN StiPartNo2 END AS [@StiPartNo2],
        (
          SELECT InvId AS [@Id], InvCode AS [@Code], InvDateAcc AS [@DateAcc],
          (
            SELECT DelId AS [@Id], DelCode AS [@Code]
            FROM Delivery WITH(NOLOCK)
            WHERE DelInvId = InvId
            FOR XML PATH('Delivery'), ROOT('DeliveryList'), TYPE
          )
          FROM Invoice WITH(NOLOCK)
            JOIN InvItem WITH(NOLOCK) ON IniInvId = InvId
          WHERE IniOriId = OriId AND InvState = 1
          FOR XML PATH('Invoice'), ROOT('InvoiceList'), TYPE
        )
      FROM OrdItem WITH(NOLOCK)
        JOIN StoItem WITH(NOLOCK) ON StiId = OriStiId
        JOIN UsrDes UsdCur WITH(NOLOCK) ON UsdCur.UsdKind = 1 AND UsdCur.UsdTabId = OriXCurId
      WHERE OriOrdId = OrdId AND OriQty - OriCanc > 0
      FOR XML PATH('OrdItem'), ROOT('OrdItemList'), TYPE
    )
    FROM Orders WITH(NOLOCK)
    WHERE OrdYSrtId = 76 AND OrdSrcId = LoaId
    FOR XML PATH('Order'), ROOT('OrderList'), TYPE
  ),
  (
    SELECT DISTINCT InvId AS [@Id], InvCode AS [@Code], InvDateAcc AS [@DateAcc]
    FROM Invoice WITH(NOLOCK)
      JOIN InvItem WITH(NOLOCK) ON IniInvId = InvId
      JOIN OrdItem WITH(NOLOCK) ON OriId = IniOriId
      JOIN Orders WITH(NOLOCK) ON OrdId = OriOrdId
    WHERE OrdYSrtId = 76 AND OrdSrcId = LoaId
    FOR XML PATH('Invoice'), ROOT('InvoiceList'), TYPE
  ),
  (
    SELECT DISTINCT DelId AS [@Id], DelCode AS [@Code]
    FROM Delivery WITH(NOLOCK)
      JOIN StoOper WITH(NOLOCK) ON DelId = SopDelId
      JOIN OrdItem WITH(NOLOCK) ON OriId = SopOriId
      JOIN Orders WITH(NOLOCK) ON OrdId = OriOrdId
    WHERE OrdYSrtId = 76 AND OrdSrcId = LoaId
    FOR XML PATH('Delivery'), ROOT('DeliveryList'), TYPE
  ),
  (
  SELECT
    CstId AS [@Id],
    CASE WHEN LTRIM(RTRIM(CstName)) <> '' THEN LTRIM(RTRIM(CstName)) ELSE NULL END AS [@Name],
    CASE WHEN LTRIM(RTRIM(CstNameAdd)) <> '' THEN LTRIM(RTRIM(CstNameAdd)) ELSE NULL END AS [@NameAdd],
    CASE WHEN LTRIM(RTRIM(CstNameAdd2)) <> '' THEN LTRIM(RTRIM(CstNameAdd2)) ELSE NULL END AS [@NameAdd2],
    CASE WHEN LTRIM(RTRIM(CstStreet)) <> '' THEN LTRIM(RTRIM(CstStreet)) ELSE NULL END AS [@Street],
    CASE WHEN LTRIM(RTRIM(CstCity)) <> '' THEN LTRIM(RTRIM(CstCity)) ELSE NULL END AS [@City],
    CASE WHEN LTRIM(RTRIM(CstPostCode)) <> '' THEN LTRIM(RTRIM(CstPostCode)) ELSE NULL END AS [@PostCode],
    CASE WHEN LTRIM(RTRIM(CstTel)) <> '' THEN LTRIM(RTRIM(CstTel)) ELSE NULL END AS [@Tel],
    CASE WHEN LTRIM(RTRIM(CstFax)) <> '' THEN LTRIM(RTRIM(CstFax)) ELSE NULL END AS [@Fax],
    CASE WHEN LTRIM(RTRIM(CstEMail)) <> '' THEN LTRIM(RTRIM(CstEMail)) ELSE NULL END AS [@EMail]
  FROM ComShipTo WITH(NOLOCK)
  WHERE CstId = LoaCstId
  FOR XML PATH('ComShipTo'), TYPE
  ),
  (
  SELECT LoiId AS [@Id], LoiDir AS [@Dir], LoiQty AS [@Qty], LoiDateTE AS [@DateTE], LoiDateOper AS [@DateOper], LoiPrc AS [@Prc], LoiPrcCur AS [@PrcCur], RTRIM(UsdCur.UsdCodeE) AS [@CurCode],
    StiId AS [@StiId], StiCode AS [@StiCode],
    CASE WHEN StiCode2 <> '' THEN StiCode2 END AS [@StiCode2],
    CASE WHEN StiPartNo <> '' THEN StiPartNo END AS [@StiPartNo],
    CASE WHEN StiPartNo2 <> '' THEN StiPartNo2 END AS [@StiPartNo2],
    OriId AS [@OriIdReq], OrdReq.OrdId AS [@OrdIdReq], OrdReq.OrdCode AS [@OrdCodeReq], CASE WHEN OrdReq.OrdCodeO <> '' THEN OrdReq.OrdCodeO END AS [@OrdCodeOReq]
  FROM LoaItem WITH(NOLOCK)
    JOIN UsrDes UsdCur WITH(NOLOCK) ON UsdCur.UsdKind = 1 AND UsdCur.UsdTabId = LoiXCurId
    JOIN StoItem WITH(NOLOCK) ON StiId = LoiStiId
    LEFT JOIN OrdItem OriReq WITH(NOLOCK) ON OriReq.OriId = LoiOriId
    LEFT JOIN Orders OrdReq WITH(NOLOCK) ON OrdReq.OrdId = OriReq.OriOrdId
  WHERE LoiLoaId = LoaId
  FOR XML PATH('LoaItem'), ROOT('LoaItemList'), TYPE
  ),
  (
    SELECT WarId AS [@WarId], WarDir AS [@Dir], WarQty AS [@Qty],
      StiId AS [@StiId], StiCode AS [@StiCode],
      CASE WHEN StiCode2 <> '' THEN StiCode2 END AS [@StiCode2],
      CASE WHEN StiPartNo <> '' THEN StiPartNo END AS [@StiPartNo],
      CASE WHEN StiPartNo2 <> '' THEN StiPartNo2 END AS [@StiPartNo2],
      RTRIM(LTRIM(WarSerialNo)) AS [@WarSerialNo]
    FROM Warranty WITH(NOLOCK)
      JOIN StoItem WITH(NOLOCK) ON WarStiId = StiId
    WHERE WarYSrtId = 76 AND WarSrcId = LoaId
      AND WarSerialNo <> ''
    FOR XML PATH('Warranty'), ROOT('WarrantyList'), TYPE
  )
FROM Loan WITH(NOLOCK)
  LEFT JOIN DelivMode WITH(NOLOCK) ON DemId = LoaDemId
WHERE LoaId IN(SELECT Id FROM #IdList WITH(NOLOCK))
FOR XML PATH('Loan'), ROOT('Result')

DROP TABLE #IdList
    ]]></Text>
    <Parameter Name="UserConId" Type="Int">
      <Value Source="Identity" Item="Name" />
      <Value Source="DBNull" />
    </Parameter>
    <Parameter Name="ParamCode" Type="VarChar">
      <Value Source="RunTime" />
      <Value Source="DBNull" />
    </Parameter>
    <Parameter Name="ParamFrom" Type="SmallDateTime">
      <Value Source="RunTime" />
      <Value Source="DBNull" />
    </Parameter>
    <Parameter Name="ParamTo" Type="SmallDateTime">
      <Value Source="RunTime" />
      <Value Source="DBNull" />
    </Parameter>
  </Command>
  </Result>  
  
  <Result Name="OrderDelivMode" Description="List of Delivery Mode for Order.asmx/Create method.">
    <Command Type="Text">
      <Text><![CDATA[
--DECLARE @UserConId int SELECT @UserConId = 10553
SET NOCOUNT ON
DECLARE @ComId int, @DemId int, @DemId2 int, @ComDemIdEnab varchar(255)
SELECT @ComId = ConComId FROM Contact WITH(NOLOCK) WHERE ConId = @UserConId
SELECT @DemId = ComDemId, @ComDemIdEnab = ComDemIdEnab FROM Company WITH(NOLOCK) WHERE ComId = @ComId
IF @DemId IS NULL SELECT TOP 1 @DemId = TasValue FROM TabSet WITH(NOLOCK) WHERE TasCode = 'DemId0' AND ISNUMERIC(TasValue) = 1
SELECT TOP 1 @DemId2 = DemDemIdB2CD FROM DelivMode WITH(NOLOCK) WHERE DemId = @DemId

SELECT /*SCHEMA TOP 0 SCHEMA*/ *
INTO #BaseResult
FROM(
  SELECT DemId AS Id, '_WS_DIST_' + RIGHT('000' + CONVERT(varchar(3), DemId), 3) AS Code, DemName AS Name, DemType AS Type,
    CONVERT(bit, CASE WHEN COALESCE(CASE WHEN DemNoteExt LIKE '%(DemHideWS: 0)%' THEN 0 END, DemHideI) = 0 OR DemId = @DemId OR DemId = @DemId2 THEN 1 END) AS IsB2B,
    CONVERT(bit, COALESCE(CASE WHEN DemZHideI = 0 THEN 1 WHEN DemZHideI = 1 THEN 0 END, CASE WHEN COALESCE(CASE WHEN DemNoteExt LIKE '%(DemHideWS: 0)%' THEN 0 END, DemHideI) = 0 OR DemId = @DemId OR DemId = @DemId2 THEN 1 END)) AS IsB2C,
    CONVERT(bit, CASE WHEN DemId = @DemId THEN 1 END) AS IsDefault,
    CASE WHEN DemDtp = 1 THEN DemId END AS DemIdDtp, CASE WHEN DemDtp = 1 THEN DemCode END AS DemCodeDtp,
    CASE WHEN DemNonMater <> 0 THEN DemNonMater END AS NonMater,
    CASE WHEN DemXXL <> 0 THEN DemXXL END AS XXL
  FROM DelivMode WITH(NOLOCK)
  WHERE (DemHideOut = 0 AND ((@ComDemIdEnab IS NULL AND (COALESCE(CASE WHEN DemNoteExt LIKE '%(DemHideWS: 0)%' THEN 0 END, DemHideI) = 0 OR DemZHideI = 0)) OR (NOT @ComDemIdEnab IS NULL AND CHARINDEX(',' + CONVERT(varchar(10), DemId) + ',', ',' + @ComDemIdEnab + ',') > 0)) AND (DemComId IS NULL OR DemComId = @ComId)) OR DemId = @DemId OR DemId = @DemId2
    UNION 
  SELECT -ZDmId AS Id, ZDmDemIdO AS Code, ZDmName AS Name,
    CASE WHEN ZDmType = 1 THEN 1 ELSE DemType END AS Type,
    0 AS IsB2B, NULL AS IsB2B, NULL AS IsDefault,
    CASE WHEN DemDtp = 1 THEN DemId END AS DemIdDtp, CASE WHEN DemDtp = 1 THEN DemCode END AS DemCodeDtp,
    CASE WHEN DemNonMater <> 0 THEN DemNonMater END AS NonMater,
    CASE WHEN DemXXL <> 0 THEN DemXXL END AS XXL
  FROM ZDelivMode WITH(NOLOCK)
    JOIN DelivMode WITH(NOLOCK) ON ZDmDemId = DemId
  WHERE ZDmHide = 0 AND ZDmDemIdO <> '' AND ZDmComId = @ComId
) OrderDelivMode

SELECT DemIdDtp AS DemId, DemToPlace.DtpId AS Id, CASE WHEN DemToPlace.DtpCode <> '' THEN DemToPlace.DtpCode END AS Code, CASE WHEN DemToPlace.DtpCodeAlt <> '' THEN DemToPlace.DtpCodeAlt END AS CodeAlt, DemToPlace.DtpName AS Name, DemToPlace.DtpStreet AS Street, DemToPlace.DtpCity AS City, RTRIM(DemTOPlace.DtpPostCode) AS PostCode
INTO #DemDtp
FROM #BaseResult WITH(NOLOCK)
  JOIN DemToPlace WITH(NOLOCK) ON DtpDemCode = DemCodeDtp
WHERE DtpHide = 0
  AND (NOT EXISTS(SELECT TOP 1 * FROM DemTOPlaceDem WITH(NOLOCK) JOIN DelivMode dm2 WITH(NOLOCK) ON dm2.DemId = DtdDtpId WHERE dm2.DemCode = DemCodeDtp) OR EXISTS(SELECT TOP 1 * FROM DemTOPlaceDem WITH(NOLOCK) WHERE DtdDtpId = DtpId AND DtdDemId = DemIdDtp))

SELECT Void,
  OrderDelivMode.Id, OrderDelivMode.Code, OrderDelivMode.Name, OrderDelivMode.Type, OrderDelivMode.IsB2B, OrderDelivMode.IsB2C, OrderDelivMode.IsDefault, OrderDelivMode.NonMater, OrderDelivMode.XXL,
  DemToPlace.Id, DemToPlace.Code, DemToPlace.CodeAlt, DemToPlace.Name, DemToPlace.Street, DemToPlace.City, DemToPlace.PostCode
FROM (SELECT /*SCHEMA TOP 0 SCHEMA*/ CONVERT(varchar(1), NULL) AS Void) AS Result
  LEFT JOIN #BaseResult OrderDelivMode ON Void IS NULL
  LEFT JOIN #DemDtp DemToPlace WITH(NOLOCK) ON DemId = DemIdDtp
ORDER BY OrderDelivMode.Code, DemIdDtp, DemId, DemToPlace.Id
FOR XML AUTO/*SCHEMA, XMLDATA SCHEMA*/

DROP TABLE #DemDtp
DROP TABLE #BaseResult
      ]]></Text>
      <Parameter Name="UserConId" Type="Int">
        <Value Source="Identity" Item="Name" />
        <Value Source="DBNull" />
      </Parameter>
    </Command>
  </Result>
  
  <Result Name="OrderPaymentMode" Description="List of Payment Mode for Order.asmx/Create method.">
    <Command Type="Text">
      <Text><![CDATA[
SET NOCOUNT ON

SELECT /*SCHEMA TOP 0 SCHEMA*/ *
INTO #BaseResult
FROM(
  SELECT UsdTabId AS PawId, RTRIM(UsdName) AS PawName, UsdType AS Type
  FROM UsrDes WITH(NOLOCK)
  WHERE UsdKind = 10 AND UsdHide = 0 AND UsdHideI = 0 AND UsdName <> ''
) OrderPaymentMode

SELECT Void, OrderPaymentMode.*
FROM (SELECT /*SCHEMA TOP 0 SCHEMA*/ CONVERT(varchar(1), NULL) AS Void) AS Result
  LEFT JOIN #BaseResult OrderPaymentMode ON Void IS NULL
ORDER BY PawId
FOR XML AUTO/*SCHEMA, XMLDATA SCHEMA*/

DROP TABLE #BaseResult
      ]]></Text>
    </Command>
  </Result>
  
  <Result Name="OrderQueue" Description="List of Queue for Order.asmx/Create/Order/@QudId method.">
    <Command Type="Text">
      <Text><![CDATA[
--DECLARE @UserConId int SELECT @UserConId = 66123
SET NOCOUNT ON

SELECT /*SCHEMA TOP 0 SCHEMA*/ UsdQud.UsdTabId AS Id, RTRIM(UsdQud.UsdCode) AS Code, UsdQud.UsdName AS Name, CASE WHEN UsdQud.UsdTabId = SrdXDefQudId THEN 1 END AS IsDef, MIN(SruOrd) AS Sort
INTO #BaseResult
FROM StoRules WITH(NOLOCK)
    JOIN Store WITH(NOLOCK) ON StoId = SruStoId
    JOIN UsrDes UsdQud WITH(NOLOCK) ON StoXQudId = UsdQud.UsdTabId AND UsdQud.UsdKind = 24
    JOIN StoRulesDef WITH(NOLOCK) ON SrdId = SruSrdId    
WHERE SruSrdId = (SELECT TOP 1 ConSrdIdOut FROM Contact WITH(NOLOCK) WHERE ConId = @UserConId)
    AND SruProh = 0 AND SruFree = 1 AND UsdQud.UsdHide = 0
GROUP BY UsdQud.UsdTabId, RTRIM(UsdQud.UsdCode), UsdQud.UsdName, CASE WHEN UsdQud.UsdTabId = SrdXDefQudId THEN 1 END

SELECT Void,
  Id, Code, Name
FROM (SELECT /*SCHEMA TOP 0 SCHEMA*/ CONVERT(varchar(1), NULL) AS Void) AS Result
  LEFT JOIN #BaseResult Queue ON Void IS NULL
ORDER BY IsDef DESC, Sort, Id
FOR XML AUTO/*SCHEMA, XMLDATA SCHEMA*/

DROP TABLE #BaseResult
      ]]></Text>
      <Parameter Name="UserConId" Type="Int">
        <Value Source="Identity" Item="Name" />
        <Value Source="DBNull" />
      </Parameter>
    </Command>
  </Result>
  
  <Result Name="OrderToken" Description="List of info about Order Token(s).">
    <Command Type="Text">
      <Text><![CDATA[
--DECLARE @UserConId int, @ParamCode varchar(8000), @ParamFrom smalldatetime, @ParamTo smalldatetime SELECT @UserConId = 586, @ParamCode = '{OrdCodeO}ORD2000024', @ParamFrom = NULL, @ParamTo = NULL
SET NOCOUNT ON

DECLARE @Sql nvarchar(max), @Tab varchar(1), @FieldCode varchar(255)
SELECT @Sql = '', @Tab = CHAR(9), @FieldCode = CASE WHEN CHARINDEX('{Id}', @ParamCode) = 1 THEN 'OrtId' WHEN CHARINDEX('{OriId}', @ParamCode) = 1 THEN 'OriId' WHEN CHARINDEX('{OrdId}', @ParamCode) = 1 THEN 'OrdId' WHEN CHARINDEX('{OrdCode}', @ParamCode) = 1 THEN 'OrdCode' WHEN CHARINDEX('{OrdCodeO}', @ParamCode) = 1 THEN 'OrdCodeO' WHEN CHARINDEX('{StiCode}', @ParamCode) = 1 THEN 'StiCode' WHEN CHARINDEX('{OtsId}', @ParamCode) = 1 THEN 'OrtXOtsId'  ELSE 'OrdCode' END, @ParamCode = CASE WHEN @ParamCode LIKE '{%}%' THEN SUBSTRING(@ParamCode, CHARINDEX('}', @ParamCode) + 1, 8000) ELSE @ParamCode END
IF NOT @ParamCode IS NULL SET @Sql = @Sql + ' AND ' + CASE WHEN CHARINDEX(CHAR(9), @ParamCode) > 0 THEN @FieldCode + ' IN(SELECT s FROM dbo.fSplit(@ParamCode, @Tab) WHERE s <> '''')' ELSE @FieldCode + ' = @ParamCode' END + CASE WHEN @FieldCode LIKE 'EXISTS(%' THEN ')' ELSE '' END
IF NOT @ParamFrom IS NULL SET @Sql = @Sql + ' AND (OrtU >= @ParamFrom)'
IF NOT @ParamTo IS NULL SET @Sql = @Sql + ' AND (OrtU <= @ParamTo)'
SET @Sql = '
SELECT /*SCHEMA TOP 0 SCHEMA*/OrtId
FROM OriToken WITH(NOLOCK)
  LEFT JOIN OrdItem WITH(NOLOCK) On (OrtOriId = OriId)
  LEFT JOIN Orders WITH(NOLOCK) On (OriOrdId = OrdId)
  LEFT JOIN StoItem WITH(NOLOCK) On (OriStiId = StiId)
WHERE OrdComId = (SELECT TOP 1 ConComId FROM Contact WITH(NOLOCK) WHERE ConId = @UserConId)' + @Sql

CREATE TABLE #BaseResult(OrtId int NOT NULL PRIMARY KEY)
INSERT INTO #BaseResult(OrtId)
EXEC sp_executesql @Sql, N'@Tab varchar(1), @ParamCode varchar(8000), @ParamFrom smalldatetime, @ParamTo smalldatetime, @UserConId int', @Tab, @ParamCode, @ParamFrom, @ParamTo, @UserConId

SELECT OrdId, OrdCode, OrdCodeO, OriId,
  StiId, StiPartNo, StiName,
  OrtId AS Id, OrtXOtsId AS OtsId, Ots.UsdName AS OtsName, OrtToken1Type AS Token1Type, CONVERT(bit, CASE WHEN DATALENGTH(OrtToken1) > 0 THEN 1 END) AS Token1Is, OrtToken1ValidEnd AS Token1ValidEnd, OrtToken2Type AS Token2Type, CONVERT(bit, CASE WHEN DATALENGTH(OrtToken2) > 0 THEN 1 END) AS Token2Is, OrtToken2Tag AS Token2Tag, OrtToken2TagU AS Token2TagU
INTO #BaseData
FROM OriToken WITH(NOLOCK)
  LEFT JOIN UsrDes Ots WITH(NOLOCK) On (OrtXOtsId = Ots.UsdTabId And Ots.UsdKind = 166)
  LEFT JOIN OrdItem WITH(NOLOCK) On (OrtOriId = OriId)
  LEFT JOIN Orders WITH(NOLOCK) On (OriOrdId = OrdId)
  LEFT JOIN StoItem WITH(NOLOCK) On (OriStiId = StiId)
WHERE OrtId IN(SELECT OrtId FROM #BaseResult WITH(NOLOCK))

SELECT /*SCHEMA TOP 0 SCHEMA*/ Void, OrderToken.*
FROM (SELECT CONVERT(varchar(1), NULL) AS Void) AS Result
  LEFT JOIN #BaseData OrderToken WITH(NOLOCK) ON Void IS NULL
FOR XML AUTO/*SCHEMA, XMLDATA SCHEMA*/

DROP TABLE #BaseData
DROP TABLE #BaseResult
      ]]></Text>
      <Parameter Name="UserConId" Type="Int">
        <Value Source="Identity" Item="Name" />
        <Value Source="DBNull" />
      </Parameter>
      <Parameter Name="ParamCode" Type="VarChar">
        <Value Source="RunTime" />
        <Value Source="DBNull" />
      </Parameter>
      <Parameter Name="ParamFrom" Type="SmallDateTime">
        <Value Source="RunTime" />
        <Value Source="DBNull" />
      </Parameter>
      <Parameter Name="ParamTo" Type="SmallDateTime">
        <Value Source="RunTime" />
        <Value Source="DBNull" />
      </Parameter>
    </Command>
  </Result>
  
  <Result Name="ComShipTo" Description="List of ShipTo address.">
    <Command Type="Text">
      <Text><![CDATA[
--DECLARE @UserConId int SELECT @UserConId = 3
SET NOCOUNT ON
DECLARE @ComId int, @DemId int
SELECT @ComId = ConComId FROM Contact WITH(NOLOCk) WHERE ConId = @UserConId

SELECT /*SCHEMA TOP 0 SCHEMA*/ 
  CstId AS Id,
  CstType AS Type,
  CstHide AS Hide,
  CstName AS Name,
  CstNameAdd AS NameAdd,
  CstNameAdd2 AS NameAdd2,
  CstStreet AS Street,
  CstCity AS City,
  CstPostCode AS PostCode,
  Rtrim(Cou.UsdCodeE) AS CouCode,
  Rtrim(Are.UsdCode) AS AreCode,
  CstTel AS Tel,
  CstFax AS Fax,
  CstEMail AS EMail,
  CstNote AS Note
INTO #BaseResult
FROM ComShipTo WITH (NOLOCK)
  JOIN UsrDes Cou WITH(NOLOCK) ON (Cou.UsdKind = 2 AND Cou.UsdTabId = CstXCouId)
  JOIN UsrDes Are WITH(NOLOCK) ON (Are.UsdKind = 3 AND Are.UsdTabId=CstXAreId)
WHERE CstComId = @ComId
                    
SELECT Void, ComShipTo.*
FROM (SELECT /*SCHEMA TOP 0 SCHEMA*/ CONVERT(varchar(1), NULL) AS Void) AS Result
  LEFT JOIN #BaseResult ComShipTo ON Void IS NULL
FOR XML AUTO/*SCHEMA, XMLDATA SCHEMA*/

DROP TABLE #BaseResult
      ]]></Text>
      <Parameter Name="UserConId" Type="Int">
        <Value Source="Identity" Item="Name" />
        <Value Source="DBNull" />
      </Parameter>
    </Command>
  </Result>
  
  <Result Name="ComBank" Description="List of client's bank accounts.">
    <Command Type="Text">
      <Text><![CDATA[
--DECLARE @UserConId int SELECT @UserConId = 3
SET NOCOUNT ON
DECLARE @ComId int, @DemId int
SELECT @ComId = ConComId FROM Contact WITH(NOLOCk) WHERE ConId = @UserConId

SELECT /*SCHEMA TOP 0 SCHEMA*/ 
  CobAccPre AS AccPre,
  CobAcc AS Acc,
  CobBacCode AS BacCode,
  CobName AS Name,
  CobSwift AS Swift,
  CobAccIBAN AS Iban,
  CONVERT(bit, CASE WHEN NOT ComId IS NULL THEN 1 END) AS IsDefault
INTO #BaseResult
FROM ComBank WITH(NOLOCK)
  LEFT JOIN Company WITH(NOLOCK) ON CobComId = ComId AND CobId = ComCobId
WHERE CobComId = @ComId AND CobHide = 0
                    
SELECT Void, ComBank.*
FROM (SELECT /*SCHEMA TOP 0 SCHEMA*/ CONVERT(varchar(1), NULL) AS Void) AS Result
  LEFT JOIN #BaseResult ComBank ON Void IS NULL
FOR XML AUTO/*SCHEMA, XMLDATA SCHEMA*/

DROP TABLE #BaseResult
      ]]></Text>
      <Parameter Name="UserConId" Type="Int">
        <Value Source="Identity" Item="Name" />
        <Value Source="DBNull" />
      </Parameter>
    </Command>
  </Result>
  
  <Result Name="Queue" Description="Delivery term.">
    <Command Type="Text">
      <Text><![CDATA[
--DECLARE @UserConId int SELECT @UserConId = 66123
SET NOCOUNT ON

SELECT /*SCHEMA TOP 0 SCHEMA*/ QueId AS Id, QueQty AS Qty, COALESCE(UsdQud.UsdTagD, QueDateShip) AS DateShip,
  RTRIM(UsdQud.UsdCode) AS QudCode, RTRIM(UsdQud.UsdName) AS QudName,
  UsdOis.UsdTabId As OisId, RTRIM(UsdOis.UsdName) As OisName,
  OriQty - OriCanc AS OriQty, OriBlock, OriQty - OriCanc - OriProc - OriDeliv AS QriQtyBacklog,
  OrdId, OrdCode, OrdCodeO,
  StiId, StiCode, StiPartNo, StiPLName
INTO #BaseResult  
FROM Queue WITH(NOLOCK)
  JOIN UsrDes UsdQud WITH(NOLOCK) ON QueXQudId = UsdQud.UsdTabId AND UsdQud.UsdKind = 24 AND UsdQud.UsdHide = 0
  JOIN OrdItem WITH(NOLOCK) ON OriId = QueOriId
  JOIN Orders WITH(NOLOCK) ON OrdId = OriOrdId
  JOIN StoItem WITH(NOLOCK) ON StiId = OriStiId
  LEFT JOIN UsrDes UsdOis WITH(NOLOCK) ON (UsdOis.UsdTabId=QueXOisId and UsdOis.UsdKind=87)
WHERE OrdComId = (SELECT ConComId FROM Contact WITH(NOLOCK) WHERE ConId = @UserConId)
  AND OrdInt = 0
  --AND COALESCE(UsdQud.UsdTagD, QueDateShip) > 0 AND COALESCE(UsdQud.UsdTagD, QueDateShip) < '20771231' --[ZAM 15.11.22 15:16] 264556
  AND QueDir = 1
ORDER BY Id

SELECT Void,
  Queue.*
FROM (SELECT /*SCHEMA TOP 0 SCHEMA*/ CONVERT(varchar(1), NULL) AS Void) AS Result
  LEFT JOIN #BaseResult Queue ON Void IS NULL
ORDER BY Id
FOR XML AUTO/*SCHEMA, XMLDATA SCHEMA*/

DROP TABLE #BaseResult
      ]]></Text>
      <Parameter Name="UserConId" Type="Int">
        <Value Source="Identity" Item="Name" />
        <Value Source="DBNull" />
      </Parameter>
    </Command>
  </Result>  
  
  <Result Name="ZShop" Description="ZShop settings.">
    <Command Type="Text">
      <Text><![CDATA[
--DECLARE @UserConId int SELECT @UserConId = 3
SET NOCOUNT ON
DECLARE @ComId int, @DemId int
SELECT @ComId = ConComId FROM Contact WITH(NOLOCk) WHERE ConId = @UserConId

SELECT StiCode AS StiCodeService
INTO #StiCodeServiceResult
FROM StoItem WITH(NOLOCK)
WHERE StiId = COALESCE(
  (SELECT TOP 1 CONVERT(int, TasValue) FROM TabSet WITH(NOLOCK) WHERE TasConId IS NULL AND ISNUMERIC(TasValue) = 1 AND TasCode = 'ZsZDmSer'),
  (SELECT TOP 1 CONVERT(int, TasValue) FROM TabSet WITH(NOLOCK) WHERE TasConId IS NULL AND ISNUMERIC(TasValue) = 1 AND TasCode = 'StiIdSer'),
  0)

SELECT /*SCHEMA TOP 0 SCHEMA*/ ZShOrdCode AS OrdCode, ZShInvCode AS InvCode, ZShDelCode AS DelCode, ZShInvFooter AS InvFooter,
  StiCodeService
INTO #BaseResult
FROM #StiCodeServiceResult WITH(NOLOCK)
  LEFT JOIN ZShop WITH(NOLOCK) ON ZShComId = @ComId
                    
SELECT Void, ZShop.*
FROM (SELECT /*SCHEMA TOP 0 SCHEMA*/ CONVERT(varchar(1), NULL) AS Void) AS Result
  LEFT JOIN #BaseResult ZShop ON Void IS NULL
FOR XML AUTO/*SCHEMA, XMLDATA SCHEMA*/

DROP TABLE #BaseResult
DROP TABLE #StiCodeServiceResult
      ]]></Text>
      <Parameter Name="UserConId" Type="Int">
        <Value Source="Identity" Item="Name" />
        <Value Source="DBNull" />
      </Parameter>
    </Command>
  </Result>
  
  <Result Name="StoItemAukroMPOrder_El" Description="Internal export for mp.aukro.cz.">
    <Visibility ComId="|0|" />
    <Command Type="Text">
      <Text><![CDATA[
--DECLARE @UserConId int, @ParamCode varchar(255) SELECT @UserConId = 586, @ParamCode = ' 970230044'
SET NOCOUNT ON
DECLARE @ShopId int
SELECT TOP 1 @ShopId = OrdId FROM Orders WITH(NOLOCK) WHERE OrdCode = @ParamCode
DECLARE @ComId int, @PrcId tinyint
SELECT @ComId = ConComId FROM Contact WITH(NOLOCK) WHERE ConId = @UserConId
SELECT @PrcId = ComPrcId FROM Company WITH(NOLOCK) WHERE ComId = @ComId

EXEC dbo.TrgX @TrgTable = 'Orders', @Id = @ShopId, @TrgType = NULL, @TrgName = 'AutoAukroShopInit'

--Aktivni produkty
SELECT StiId AS lStiId, lStiQty, ISNULL(lStiPrc, $0) AS lStiPrc, ISNULL(lStiPostSize, 'A') AS lStiPostSize, lStiName
INTO #lSti
FROM StoItem WITH(NOLOCK)
  JOIN (
    SELECT OriStiId AS lOriStiId,
      SUM(CASE WHEN CHARINDEX('AukroShopQtyFreeField_', OrdNoteInt) > 0 THEN ISNULL(CASE WHEN CHARINDEX('AukroShopQtyFreeField_OriBlock', OrdNoteInt) > 0 THEN OriBlock END, 0) + ISNULL(CASE WHEN CHARINDEX('AukroShopQtyFreeField_SixQtyI', OrdNoteInt) > 0 THEN SixQtyI END, 0) ELSE OriQty - OriCanc END) AS lStiQty,
      MIN(CASE WHEN OrdZCmId IS NULL THEN OriPrc ELSE OriPrcZ END) AS lStiPrc,
      MAX(CpsAPSTag) AS lStiPostSize,
      MAX(CASE WHEN OriName <> '' THEN OriName END) AS lStiName
    FROM OrdItem WITH(NOLOCK)
      JOIN Orders WITH(NOLOCK) ON OrdId = OriOrdId
      LEFT JOIN StoItemX WITH(NOLOCK) ON SixStiId = OriStiId
      LEFT JOIN (SELECT CpsConId AS CpsAPSOriId, CONVERT(varchar(1), CpsTag) AS CpsAPSTag FROM ConParSet WITH(NOLOCK) JOIN ConPar WITH(NOLOCK) ON CpaId = CpsCpaId WHERE CpaYSrtId = 11 AND CpaGrp = 'AUK' AND CpaCode = 'APS') tCpaAPS ON CpsAPSOriId = OriId
    WHERE OriYSitId <> 1 AND OriQty - OriCanc > 0
      AND OrdId = @ShopId
    GROUP BY OriStiId
  ) lOri ON StiId = lOriStiId
--  LEFT JOIN StoItemX WITH(NOLOCK) ON SixStiId = StiId
WHERE lStiQty > 0 --Aktivni produkty skladem
ORDER BY StiId

SELECT DISTINCT OriStiId AS lStiId INTO #lStiAll FROM OrdItem WITH(NOLOCK) WHERE OriOrdId = @ShopId

--Export produktu
SELECT 
  StiId AS Id,
  StiCode AS Code,
  CASE WHEN NOT lStiId IS NULL THEN COALESCE(CASE WHEN lStiName <> '' THEN lStiName END, CASE WHEN StiSLName <> '' THEN StiSLName END, StiPLName) ELSE 'x - ' + StiCode END AS Name,
  CONVERT(money, lStiPrc) AS PriceNetto,
  TaxRate,
  CONVERT(int, NULL) AS PriceBrutto, --ZAM 2019-04-16 215421
  1 AS OfferType, 2 AS OfferDuration, --ZAM 2019-05-07 215421
  CONVERT(int, CASE WHEN NOT lStiId IS NULL THEN lStiQty ELSE 0 END) AS OfferQuantity, --ZAM 2019-04-16 215421
  COALESCE(CASE WHEN AttAS.AttNote <> '' THEN AttAS.AttNote END, CASE WHEN StiPLNote  <> '' THEN StiPLNote END, CASE WHEN StiShortPLNote <> '' THEN StiShortPLNote END, '') AS Description,
  CONVERT(varchar(max), NULL) AS Description2,
  CONVERT(money, NULL) AS PriceRef, CONVERT(money, NULL) AS PriceRef2
INTO #STI
FROM StoItem WITH(NOLOCK)
  LEFT JOIN #lSti WITH(NOLOCK) ON lStiId = StiId
  LEFT JOIN Tax WITH(NOLOCK) ON TaxId = StiTaxId
  LEFT JOIN Attach AttAS WITH(NOLOCK) ON AttAS.AttPedId = 52 AND AttAS.AttName = 'AukroShop' AND AttAS.AttSrcId = StiId
WHERE StiId IN(SELECT lStiId FROM #lStiAll WITH(NOLOCK)) -- + drive odeslane, at se skryji

EXEC dbo.WsRefApply @ComId = @ComId, @DataTableName = '#STI', @DataPK = 'Id', @DataFieldPrice = 'PriceNetto', @FieldsDef = 'PriceRef=PriceRef,PriceRef2=PriceRef2'

UPDATE #STI SET PriceNetto = ROUND($999999 / ($1 + TaxRate / $100), 2) WHERE ISNULL(PriceNetto, $0) = $0

UPDATE #STI SET PriceNetto = ROUND((PriceNetto + ISNULL(PriceRef, $0) + ISNULL(PriceRef2, $0)), TasDecPlcsPrc)
FROM #STI
JOIN StoItem WITH(NOLOCK) ON StiId = Id
JOIN StoItemPrice WITH(NOLOCK) ON SipStiId = Id
CROSS JOIN (SELECT TOP 1 CONVERT(int, TasValue) AS TasDecPlcsPrc FROM TabSet WITH(NOLOCK) WHERE TasConId IS NULL AND TasCode = 'DecPlcsPrc') tTasDecPlcsPrc  
CROSS JOIN (SELECT TOP 1 CONVERT(int, TasValue) AS TasDecPlcsRF FROM TabSet WITH(NOLOCK) WHERE TasConId IS NULL AND TasCode = 'DecPlcsRF') tTasDecPlcsPrcRF
UPDATE #STI SET PriceBrutto = ROUND(PriceNetto * ($1 + TaxRate / $100), 0) FROM #STI

--Update externi poznamky na HTML
UPDATE #STI SET Description = REPLACE(Description, CHAR(13) + CHAR(10), '<br/>' + CHAR(13) + CHAR(10)) WHERE Description <> '' AND NOT Description LIKE '%/>%' AND NOT Description LIKE '%</%' AND Description LIKE '%' + CHAR(13) + CHAR(10) + '%'
--Doplneni kodu do poznamky jako html komentar
UPDATE #STI SET Description = Description + CONVERT(varchar(2), CASE WHEN Description <> '' THEN CHAR(13) + CHAR(10) ELSE '' END) + '<!-- I6:CODE(' + Code + ') -->'

DECLARE @UrlBase varchar(255), @UrlBase2 varchar(255), @UrlBaseImg varchar(255), @UrlBaseThumbnail varchar(255), @UrlBaseEnlargement varchar(255), @UrlBaseTmp varchar(255), @UrlBaseImgGalery varchar(255)

  SET @UrlBase = (SELECT TOP 1 TasValue FROM TabSet WITH(NOLOCK) WHERE TasCode = 'StiExtLink' AND TasConId IS NULL AND CHARINDEX('/showdoc.do?', TasValue) > 0)
  IF NOT @UrlBase IS NULL
  BEGIN
    SELECT @UrlBaseTmp = LEFT(@UrlBase, CHARINDEX('/showdoc.do?', @UrlBase)), @UrlBaseImg = @UrlBaseTmp + 'servlet/Image?prodCode=', @UrlBaseThumbnail = @UrlBaseTmp + 'servlet/Image?width=80&height=80&prodCode=', @UrlBase = LEFT(@UrlBase, LEN(@UrlBase) - LEN('#StiId#'))
  END
  ELSE
  BEGIN
    SET @UrlBase = (SELECT TOP 1 TasValue FROM TabSet WITH(NOLOCK) WHERE TasCode = 'WWWRoot' AND TasConId IS NULL AND TasValue <> '')
    IF NOT @UrlBase IS NULL
    BEGIN
      SELECT @UrlBase2 = ISNULL((SELECT TOP 1 TasValue FROM TabSet WITH(NOLOCK) WHERE TasCode = 'WWWRootImg' AND TasConId IS NULL AND TasValue <> ''), @UrlBase), @UrlBase = CASE WHEN CHARINDEX('://', @UrlBase) > 0 THEN CASE RIGHT(@UrlBase, 1) WHEN '/' THEN @UrlBase ELSE @UrlBase + '/' END ELSE 'https://' + CASE RIGHT(@UrlBase, 1) WHEN '/' THEN @UrlBase ELSE @UrlBase + '/' END END, @UrlBase2 = CASE WHEN CHARINDEX('://', @UrlBase2) > 0 THEN CASE RIGHT(@UrlBase2, 1) WHEN '/' THEN @UrlBase2 ELSE @UrlBase2 + '/' END ELSE 'https://' + CASE RIGHT(@UrlBase2, 1) WHEN '/' THEN @UrlBase2 ELSE @UrlBase2 + '/' END END, @UrlBaseImg = @UrlBase2 + 'img.asp?stiid=', @UrlBaseThumbnail = @UrlBase2 + 'img.asp?attname=thumbnail&attpedid=52&attsrcid=', @UrlBaseEnlargement = @UrlBase2 + 'img.asp?attname=enlargement&attpedid=52&attsrcid=', @UrlBaseImgGalery = @UrlBase2 + 'img.asp?attid=', @UrlBase = @UrlBase + 'default.asp?cls=stoitem&stiid='
    END
  END

--Produktu muzou mit MAX 8 obrazku, tak vybrani mnoziny pro export do max 8/StiId, at nedochazi porad k chybam: ERR_INVALID_IMAGECOUNT
SELECT RowNo = IDENTITY(int, 1, 1), *
INTO #IMG
FROM (
  SELECT AttId AS ImgId, CONVERT(int, CASE WHEN AttTag = 'sys-enl' THEN -2147483648 ELSE AttSort END) AS ImgSort, AttSrcId AS ImgStiId, @UrlBaseImgGalery + CONVERT(varchar(10), AttId) AS ImgUrl
  FROM Attach WITH(NOLOCK) 
  WHERE DATALENGTH(AttPic) > 0 AND AttPedId = 52 AND AttTag IN('sys-enl', 'sys-gal-enl')
  UNION ALL
  SELECT -StiId AS ImgId, -2147483648 AS ImgSort, StiId AS ImgStiId, @UrlBaseImg + CONVERT(varchar(10), StiId) AS ImgUrl
  FROM StoItem WITH(NOLOCK) 
  WHERE DATALENGTH(StiPLPict) > 0 AND NOT EXISTS(SELECT TOP 1 * FROM Attach WITH(NOLOCK) WHERE DATALENGTH(AttPic) > 0 AND AttPedId = 52 AND AttSrcId = StiId AND AttTag IN('sys-enl'))
) t
WHERE ImgStiId IN(SELECT lStiId FROM #lSti WITH(NOLOCK))
ORDER BY ImgStiId, ImgSort, ImgId

--Precislovani obrazku
UPDATE #IMG SET ImgSort = NULL
DECLARE @ImgId int, @ImgStiId int, @ImgStiIdO int, @ImgSort int
SET @ImgStiIdO = -1
DECLARE c CURSOR LOCAL FAST_FORWARD FOR
  SELECT ImgId, ImgStiId FROM #IMG WITH(NOLOCK) ORDER BY RowNo
OPEN c
FETCH NEXT FROM c INTO @ImgId, @ImgStiId
WHILE (@@FETCH_STATUS <> -1)
BEGIN
  IF @ImgStiId <> @ImgStiIdO SELECT @ImgSort = 0, @ImgStiIdO = @ImgStiId
  SET @ImgSort = @ImgSort + 1
  UPDATE #IMG SET ImgSort = @ImgSort WHERE ImgId = @ImgId
  FETCH NEXT FROM c INTO @ImgId, @ImgStiId
END
CLOSE c
DEALLOCATE c

--Zpracovani poznamky z template
DECLARE @Desc2 varchar(max)
SELECT TOP 1 @Desc2 = CONVERT(varchar(max), CONVERT(varbinary(max), AttPic)) FROM Attach WITH(NOLOCK) WHERE AttPedId = 30 AND AttSrcId = @ShopId
IF NOT @Desc2 IS NULL
BEGIN
  UPDATE #STI SET Description2 = REPLACE(REPLACE(REPLACE(REPLACE(REPLACE(@Desc2, '<%Name%>', ISNULL(Name, '')), '<%Code%>', ISNULL(Code, '')), '<%Description%>', ISNULL(Description, '')), '<%PriceBrutto%>', ISNULL(CONVERT(varchar(20), PriceBrutto), '')), '<%ImgUrl1%>', ISNULL((SELECT TOP 1 ImgUrl FROM #IMG WITH(NOLOCK) WHERE ImgStiId = Id AND ImgSort = 1), ''))
END

SELECT CONVERT(varchar(50), Name) AS Name,
  Code,
  CONVERT(int, PriceBrutto) AS PriceBrutto, CONVERT(int, PriceBrutto) AS StartingPrice,
  CONVERT(int, OfferQuantity) AS OfferQuantity,
  OfferType,
  OfferDuration,
  Description,
  i1.ImgUrl AS ImgUrl1,
  i2.ImgUrl AS ImgUrl2,
  i3.ImgUrl AS ImgUrl3,
  i4.ImgUrl AS ImgUrl4,
  i5.ImgUrl AS ImgUrl5,
  i6.ImgUrl AS ImgUrl6,
  i7.ImgUrl AS ImgUrl7,
  i8.ImgUrl AS ImgUrl8,
  Description2
FROM #STI WITH(NOLOCK)
  LEFT JOIN #IMG i1 WITH(NOLOCK) ON i1.ImgStiId = Id AND i1.ImgSort = 1
  LEFT JOIN #IMG i2 WITH(NOLOCK) ON i2.ImgStiId = Id AND i2.ImgSort = 2
  LEFT JOIN #IMG i3 WITH(NOLOCK) ON i3.ImgStiId = Id AND i3.ImgSort = 3
  LEFT JOIN #IMG i4 WITH(NOLOCK) ON i4.ImgStiId = Id AND i4.ImgSort = 4
  LEFT JOIN #IMG i5 WITH(NOLOCK) ON i5.ImgStiId = Id AND i5.ImgSort = 5
  LEFT JOIN #IMG i6 WITH(NOLOCK) ON i6.ImgStiId = Id AND i6.ImgSort = 6
  LEFT JOIN #IMG i7 WITH(NOLOCK) ON i7.ImgStiId = Id AND i7.ImgSort = 7
  LEFT JOIN #IMG i8 WITH(NOLOCK) ON i8.ImgStiId = Id AND i8.ImgSort = 8
ORDER BY Id
FOR XML PATH('StoItem'), ROOT('Result')

DROP TABLE #lSti
DROP TABLE #lStiAll
DROP TABLE #STI
DROP TABLE #IMG
      ]]></Text>
      <Parameter Name="UserConId" Type="Int">
        <Value Source="Identity" Item="Name" />
        <Value Source="DBNull" />
      </Parameter>
      <Parameter Name="ParamCode" Type="VarChar">
        <Value Source="RunTime" />
        <Value Source="DBNull" />
      </Parameter>
    </Command>
  </Result>

  <Result Name="Reclaim" Description="Export of Reclaim details. Default.asmx/GetResult?resultType=Reclaim | Default.asmx/GetResultByCode?resultType=Reclaim&amp;Code=">
    <Command Type="Text" Timeout="60">
      <Text><![CDATA[
--DECLARE @UserConId int, @ParamCode varchar(255), @ParamFrom smalldatetime, @ParamTo smalldatetime SELECT @UserConId = NULL, @ParamCode = NULL, @ParamFrom = NULL, @ParamTo = NULL
SET NOCOUNT ON
SELECT 
  RecId AS [@Id], LTRIM(RTRIM(RecCode)) AS [@Code], RecC AS [@Date], RecSerialNo As [@SerialNo],
  (Case When RecDateCusB is null and RecDateCan is null Then 1 Else 0 End) As [@OpenToCus],
  RecNotCheck AS [@NotCheck], RecWar AS [@War], RecWarExpir AS [@WarExpir], RecUnRepair AS [@UnRepair], RecNonAccept AS [@NonAccept], Case When RecDateCan is null Then 0 Else 1 End As [@Can], 
  RecNoteE As [@NoteE], RecNoteTec AS [@NoteTec], RecNoteAcc As [@NoteAcc], RecQty As [@Qty],
  Case When TimeU.UsdTagC = 'd' Then DATEADD(d, StoItem.StiWarDur, Convert(datetime, RecDelDate)) When TimeU.UsdTagC = 'm' Then DATEADD(m, StoItem.StiWarDur, Convert(datetime, RecDelDate)) When TimeU.UsdTagC = 'y' Then DATEADD(yy, StoItem.StiWarDur, Convert(datetime, RecDelDate)) Else (Convert(datetime, RecDelDate) + (StoItem.StiWarDur * TimeU.UsdTagI)) End As [@WarDurEndD],  
  Convert(bit, Case When DateDiff(d, GetDate(), Case When TimeU.UsdTagC = 'd' Then DATEADD(d, StoItem.StiWarDur, Convert(datetime, RecDelDate)) When TimeU.UsdTagC = 'm' Then DATEADD(m, StoItem.StiWarDur, Convert(datetime, RecDelDate)) When TimeU.UsdTagC = 'y' Then DATEADD(yy, StoItem.StiWarDur, Convert(datetime, RecDelDate)) Else (Convert(datetime, RecDelDate) + (StoItem.StiWarDur * TimeU.UsdTagI)) End)  < 0 Then 0 Else 1 End) AS [@WarDurPending],
  ReclaimType.UsdName As [@Type], Rea.UsdName As [@ReturnType],
  --(Case When (RecDateVenB is null And RecNotToVen=0 Or RecDateCusB is null) and RecDateCan is null Then 1 Else 0 End) As [@Open],  
  StoItem.StiId AS [StoItem/@Id], StoItem.StiCode AS [StoItem/@Code], Coalesce(RecName,StoItem.StiName) AS [StoItem/@Name], CONVERT(varchar(255), RecWarDur) + ' ' + TimeU.UsdName As [StoItem/@WarDur], --XWarTimId.UsdName As XWarTimId,
  RecStiIdCus AS [StoItemCus/@Id], StoItemCus.StiCode AS [StoItemB/@Code], StoItemCus.StiName AS [StoItemB/@Name], CONVERT(varchar(255), StoItemCus.StiWarDur) + ' ' + TimeU.UsdName As [StoItemB/@WarDur], --XWarTimId.UsdName As XWarTimId,
  RecDelId AS [Delivery/@Id], RecDelCode AS [Delivery/@Code], RecDelDate AS [Delivery/@Date],  
  RecDemIdCus AS [DelivModeCus/@Id], RecDateCus AS [DelivModeCus/@Date], Cus.DemName As [DelivModeCus/@Name],
  RecDemIdCusB AS [DelivModeCusB/@Id], RecDateCusB AS [DelivModeCusB/@Date], CusB.DemName As [DelivModeCusB/@Name],
  --RecDateCusBHandR, 
  RecDateCusBHand AS [CusBHand/@Date], TakeBy.ConLName + ' ' + TakeBy.ConFName  AS [CusBHand/@Name],
  CstId AS [ComShipTo/@Id],
  CASE WHEN LTRIM(RTRIM(CstName)) <> '' THEN LTRIM(RTRIM(CstName)) ELSE NULL END AS [ComShipTo/@Name],
  CASE WHEN LTRIM(RTRIM(CstNameAdd)) <> '' THEN LTRIM(RTRIM(CstNameAdd)) ELSE NULL END AS [ComShipTo/@NameAdd],
  CASE WHEN LTRIM(RTRIM(CstNameAdd2)) <> '' THEN LTRIM(RTRIM(CstNameAdd2)) ELSE NULL END AS [ComShipTo/@NameAdd2],
  CASE WHEN LTRIM(RTRIM(CstStreet)) <> '' THEN LTRIM(RTRIM(CstStreet)) ELSE NULL END AS [ComShipTo/@Street],
  CASE WHEN LTRIM(RTRIM(CstCity)) <> '' THEN LTRIM(RTRIM(CstCity)) ELSE NULL END AS [ComShipTo/@City],
  CASE WHEN LTRIM(RTRIM(CstPostCode)) <> '' THEN LTRIM(RTRIM(CstPostCode)) ELSE NULL END AS [ComShipTo/@PostCode],
  CASE WHEN LTRIM(RTRIM(CstTel)) <> '' THEN LTRIM(RTRIM(CstTel)) ELSE NULL END AS [ComShipTo/@Tel],
  CASE WHEN LTRIM(RTRIM(CstFax)) <> '' THEN LTRIM(RTRIM(CstFax)) ELSE NULL END AS [ComShipTo/@Fax],
  CASE WHEN LTRIM(RTRIM(CstEMail)) <> '' THEN LTRIM(RTRIM(CstEMail)) ELSE NULL END AS [ComShipTo/@EMail]
  FROM Reclaim WITH(NOLOCK)
  JOIN StoItem WITH(NOLOCK) ON RecStiId = StiId
  Left Join Delivery With (NOLOCK) On (RecDelId=DelId)
  LEFT JOIN StoItem StoItemCus WITH(NOLOCK) ON RecStiIdCus = StoItemCus.StiId    
  LEFT JOIN ComShipTo WITH(NOLOCK) ON RecCstId = CstId
  LEFT JOIN DelivMode Cus WITH(NOLOCK) ON RecDemIdCus = Cus.DemId
  LEFT JOIN DelivMode CusB WITH(NOLOCK) ON RecDemIdCusB = CusB.DemId
  LEFT JOIN Contact TakeBy WITH(NOLOCK) ON RecTakeBy = TakeBy.ConId
  LEFT JOIN UsrDes TimeU WITH(NOLOCK) ON RecXWarTimId = TimeU.UsdTabId AND TimeU.UsdKind = 4
  LEFT JOIN UsrDes ReclaimType WITH(NOLOCK) ON RecXRetId = ReclaimType.UsdTabId AND ReclaimType.UsdKind = 22
  LEFT JOIN UsrDes Rea WITH(NOLOCK) ON RecXRrtId = Rea.UsdTabId AND Rea.UsdKind = 101
  WHERE RecComId = (SELECT ConComId FROM Contact WITH(NOLOCK) WHERE ConId = @UserConId)
  AND (@ParamCode IS NULL OR RecCode = RIGHT('         ' + @ParamCode, 10))
  AND (@ParamFrom IS NULL OR RecU >= @ParamFrom) 
  AND (@ParamTo IS NULL OR RecU <= @ParamTo)   
  AND (NOT @ParamCode IS NULL OR NOT @ParamFrom IS NULL OR NOT @ParamTo IS NULL OR (CASE WHEN RecDateCusB IS NULL AND RecDateCan IS NULL THEN 1 ELSE 0 END)=1)
  --OTVERENE AND ((Case When (RecDateVenB is null And RecNotToVen=0 Or RecDateCusB is null) and RecDateCan is null Then 1 Else 0 End)=1)
FOR XML PATH('Reclaim'), ROOT('Result')
]]></Text>
      <Parameter Name="UserConId" Type="Int">
        <Value Source="Identity" Item="Name" />
        <Value Source="DBNull" />
      </Parameter>
      <Parameter Name="ParamCode" Type="VarChar">
        <Value Source="RunTime" />
        <Value Source="DBNull" />
      </Parameter>
      <Parameter Name="ParamFrom" Type="SmallDateTime">
        <Value Source="RunTime" />
        <Value Source="DBNull" />
      </Parameter>
      <Parameter Name="ParamTo" Type="SmallDateTime">
        <Value Source="RunTime" />
        <Value Source="DBNull" />
      </Parameter>
    </Command>
  </Result>

  <Result Name="Service" Description="Export of Service details. Default.asmx/GetResult?resultType=Service | Default.asmx/GetResultByCode?resultType=Service&amp;Code=">
    <Command Type="Text" Timeout="60">
      <Text><![CDATA[
--DECLARE @UserConId int, @ParamCode varchar(255), @ParamFrom smalldatetime, @ParamTo smalldatetime SELECT @UserConId = NULL, @ParamCode = NULL, @ParamFrom = NULL, @ParamTo = NULL
SET NOCOUNT ON
SELECT 
  SerId AS [@Id], LTRIM(RTRIM(SerCode)) AS [@Code], SerC AS [@Date], SerSerialNo As [@SerialNo],
  (CASE WHEN SerDateCusB is null and SerDateCan is null THEN 1 ELSE 0 END) AS [@OpenToCus],
  SerNotCheck AS [@NotCheck], SerWar AS [@War], SerWarExpir AS [@WarExpir], SerNonAccept AS [@NonAccept], CASE WHEN SerDateCan is null THEN 0 ELSE 1 END AS [@Can], 
  SerNoteE AS [@NoteE], SerNoteDmg AS [@NoteDamage], SerNoteTec AS [@NoteTec], SerNoteAcc AS [@NoteAcc], SerQty AS [@Qty],
  CASE WHEN TimeU.UsdTagC = 'd' THEN DATEADD(d, StoItem.StiWarDur, Convert(datetime, SerDelDate)) WHEN TimeU.UsdTagC = 'm' THEN DATEADD(m, StoItem.StiWarDur, Convert(datetime, SerDelDate)) WHEN TimeU.UsdTagC = 'y' THEN DATEADD(yy, StoItem.StiWarDur, Convert(datetime, SerDelDate)) ELSE (Convert(datetime, SerDelDate) + (StoItem.StiWarDur * TimeU.UsdTagI)) END AS [@WarDurEnd],  
  Convert(bit, CASE WHEN DateDiff(d, GetDate(), CASE WHEN TimeU.UsdTagC = 'd' THEN DATEADD(d, StoItem.StiWarDur, Convert(datetime, SerDelDate)) WHEN TimeU.UsdTagC = 'm' THEN DATEADD(m, StoItem.StiWarDur, Convert(datetime, SerDelDate)) WHEN TimeU.UsdTagC = 'y' THEN DATEADD(yy, StoItem.StiWarDur, Convert(datetime, SerDelDate)) ELSE (Convert(datetime, SerDelDate) + (StoItem.StiWarDur * TimeU.UsdTagI)) END)  < 0 THEN 0 ELSE 1 END) AS [@WarDurPenDing],
  ServiceType.UsdName As [@Type], ServiceState.UsdName As [@State], ServiceReturnType.UsdName AS [@ReturnType],
  --(CASE WHEN (SerDateVenB is null And SerNotToVen=0 Or SerDateCusB is null) and SerDateCan is null THEN 1 ELSE 0 END) AS [@Open],
  SerDateCus AS [ServiceProcess/@Received], SerDateRea AS [ServiceProcess/@Realized], SerDateCusB AS [ServiceProcess/@Finished], SerDateS AS [ServiceProcess/@Send],
  SerPrcE AS [ServicePrices/@Price], SerPrcM AS [ServicePrices/@PriceMax], SerAdvPay AS [ServicePrices/@PriceAdvance],
  StoItem.StiId AS [StoItem/@Id], StoItem.StiCode AS [StoItem/@Code], Coalesce(SerName,StoItem.StiName) AS [StoItem/@Name], CONVERT(varchar(255), SerWarDur) + ' ' + TimeU.UsdName As [StoItem/@WarDur], --XWarTimId.UsdName As XWarTimId,  
  SerDelId AS [Delivery/@Id], DelCode AS [Delivery/@Code], SerDelDate AS [Delivery/@Date],  
  SerDemIdCus AS [DelivModeCus/@Id], SerDateCus AS [DelivModeCus/@Date], Cus.DemName AS [DelivModeCus/@Name],
  SerDemIdCusB AS [DelivModeCusB/@Id], SerDateCusB AS [DelivModeCusB/@Date], CusB.DemName AS [DelivModeCusB/@Name],
  CstId AS [ComShipTo/@Id],
  CASE WHEN LTRIM(RTRIM(CstName)) <> '' THEN LTRIM(RTRIM(CstName)) ELSE NULL END AS [ComShipTo/@Name],
  CASE WHEN LTRIM(RTRIM(CstNameAdd)) <> '' THEN LTRIM(RTRIM(CstNameAdd)) ELSE NULL END AS [ComShipTo/@NameAdd],
  CASE WHEN LTRIM(RTRIM(CstNameAdd2)) <> '' THEN LTRIM(RTRIM(CstNameAdd2)) ELSE NULL END AS [ComShipTo/@NameAdd2],
  CASE WHEN LTRIM(RTRIM(CstStreet)) <> '' THEN LTRIM(RTRIM(CstStreet)) ELSE NULL END AS [ComShipTo/@Street],
  CASE WHEN LTRIM(RTRIM(CstCity)) <> '' THEN LTRIM(RTRIM(CstCity)) ELSE NULL END AS [ComShipTo/@City],
  CASE WHEN LTRIM(RTRIM(CstPostCode)) <> '' THEN LTRIM(RTRIM(CstPostCode)) ELSE NULL END AS [ComShipTo/@PostCode],
  CASE WHEN LTRIM(RTRIM(CstTel)) <> '' THEN LTRIM(RTRIM(CstTel)) ELSE NULL END AS [ComShipTo/@Tel],
  CASE WHEN LTRIM(RTRIM(CstFax)) <> '' THEN LTRIM(RTRIM(CstFax)) ELSE NULL END AS [ComShipTo/@Fax],
  CASE WHEN LTRIM(RTRIM(CstEMail)) <> '' THEN LTRIM(RTRIM(CstEMail)) ELSE NULL END AS [ComShipTo/@EMail],
  SerInsur AS [Insurance/@Insurance], ServiceInsurance.UsdName AS [Insurance/@InsurCompany], SerInsurCode AS [Insurance/@EventCode], SerInsurAgrCodeO AS [Insurance/@Contract], SerPrcPart AS [Insurance/@Participation]
  FROM Service WITH(NOLOCK)
  JOIN StoItem WITH(NOLOCK) ON SerStiId = StiId
  LEFT JOIN Delivery With (NOLOCK) On (SerDelId=DelId)
  LEFT JOIN ComShipTo WITH(NOLOCK) ON SerCstId = CstId
  LEFT JOIN DelivMode Cus WITH(NOLOCK) ON SerDemIdCus = Cus.DemId
  LEFT JOIN DelivMode CusB WITH(NOLOCK) ON SerDemIdCusB = CusB.DemId
  LEFT JOIN UsrDes TimeU WITH(NOLOCK) ON SerXWarTimId = TimeU.UsdTabId AND TimeU.UsdKind = 4
  LEFT JOIN UsrDes ServiceType WITH(NOLOCK) ON SerXSetId = ServiceType.UsdTabId AND ServiceType.UsdKind = 65
  LEFT JOIN UsrDes ServiceState WITH(NOLOCK) ON SerXSesId = ServiceState.UsdTabId AND ServiceState.UsdKind = 66
  LEFT JOIN UsrDes ServiceReturnType WITH(NOLOCK) ON SerXSetIdC = ServiceReturnType.UsdTabId AND ServiceReturnType.UsdKind = 65
  LEFT JOIN UsrDes ServiceInsurance WITH(NOLOCK) ON SerXSidId = ServiceInsurance.UsdTabId AND ServiceInsurance.UsdKind = 176  
  WHERE SerComId = (SELECT ConComId FROM Contact WITH(NOLOCK) WHERE ConId = @UserConId)
  AND (@ParamCode IS NULL OR SerCode = RIGHT('         ' + @ParamCode, 10))
  AND (@ParamFrom IS NULL OR SerU >= @ParamFrom) 
  AND (@ParamTo IS NULL OR SerU <= @ParamTo)   
  --AND (NOT @ParamCode IS NULL OR NOT @ParamFrom IS NULL OR NOT @ParamTo IS NULL OR (CASE WHEN SerDateCusB IS NULL AND SerDateCan IS NULL THEN 1 ELSE 0 END)=1)  
FOR XML PATH('Service'), ROOT('Result')
]]></Text>
      <Parameter Name="UserConId" Type="Int">
        <Value Source="Identity" Item="Name" />
        <Value Source="DBNull" />
      </Parameter>
      <Parameter Name="ParamCode" Type="VarChar">
        <Value Source="RunTime" />
        <Value Source="DBNull" />
      </Parameter>
      <Parameter Name="ParamFrom" Type="SmallDateTime">
        <Value Source="RunTime" />
        <Value Source="DBNull" />
      </Parameter>
      <Parameter Name="ParamTo" Type="SmallDateTime">
        <Value Source="RunTime" />
        <Value Source="DBNull" />
      </Parameter>
    </Command>
  </Result>
  
</ResultList>
