  <Result Name="DocTrExp" Description="Document Transfer - Expedition (Format for import into I6).">
  <Command Type="Text" Timeout="90">
    <Text><![CDATA[
--DECLARE @UserConId int, @ParamCode varchar(255), @ParamFrom smalldatetime, @ParamTo smalldatetime SELECT @UserConId = 4129, @ParamCode = NULL, @ParamFrom = '1900-01-01', @ParamTo = NULL
SET NOCOUNT ON
DECLARE @Sql nvarchar(max)
SET @Sql = ''
IF NOT @ParamCode IS NULL SET @Sql = @Sql + ' AND RTRIM(LTRIM(ExpCode)) = @ParamCode'
--[ZAM 16.09.22 09:35] 208563 pokud je v hlavni podm. ExpDateS musi byt i zde ExpDateS
IF NOT @ParamFrom IS NULL SET @Sql = @Sql + ' AND ExpDateS >= @ParamFrom'
IF NOT @ParamTo IS NULL SET @Sql = @Sql + ' AND ExpDateS <= @ParamTo'
IF @Sql = '' SET @Sql = @Sql + ' AND ExpDateS >= CONVERT(smalldatetime, CONVERT(char(10), (GETDATE() - 1), 120))'
SET @Sql = 'SELECT /*SCHEMA TOP 0 SCHEMA*/ExpId FROM Expedition WITH(NOLOCK) WHERE ExpComId = (SELECT ConComId FROM Contact WITH(NOLOCK) WHERE ConId = @UserConId) AND NOT ExpDateS IS NULL' + @Sql

CREATE TABLE #IdList(Id int PRIMARY KEY)
INSERT INTO #IdList
EXEC sp_executesql @Sql, N'@UserConId int, @ParamCode varchar(255), @ParamFrom smalldatetime, @ParamTo smalldatetime', @UserConId, @ParamCode, @ParamFrom, @ParamTo

SELECT ExpId AS Id, ExpCode AS Code, ExpCodeO AS CodeO, ExpCodeS AS CodeS, ExpDateS AS DateS, ExpC AS C, CONVERT(varchar(2048), NULL) AS ExpTrackUrl, DemName
INTO #Expedition
FROM Expedition WITH(NOLOCK)
  JOIN DelivMode WITH(NOLOCK) ON ExpDemId = DemId
WHERE ExpId IN(SELECT Id FROM #IdList WITH(NOLOCK)) 
--[ZAM 17.02.25 11:21] 289121 Nahrazeno fGetParcelURL: CASE WHEN DemWwwLink <> '' THEN REPLACE(REPLACE(REPLACE(DemWwwLink, '#CodeO#', ExpCodeO), '#CodeS#', ExpCodeS), '#CodeS[17,27]#', SUBSTRING(ExpCodeS, 17, 11)) END
UPDATE #Expedition SET ExpTrackUrl = dbo.fGetParcelURL(Id) WHERE CodeO <> '' OR CodeS <> ''

SELECT ExdExpId AS ExpId, ExdId AS Id, ExdYSrtId AS SrtId, COALESCE(dSrt.DelCode, d.DelCode) AS DelCode, COALESCE(iSrt.InvCode, i.InvCode) AS InvCode, NULLIF(COALESCE(oSrt.OrdCode, o.OrdCode), '') AS OrdCode, NULLIF(COALESCE(oSrt.OrdCodeO, o.OrdCodeO), '') AS OrdCodeO
INTO #ExpDocument
FROM ExpDocuments WITH(NOLOCK)
  LEFT JOIN Delivery dSrt WITH(NOLOCK) ON ExdSrcId = dSrt.DelId AND ExdYSrtId = 68
  LEFT JOIN Invoice iSrt WITH(NOLOCK) ON ExdSrcId = iSrt.InvId AND ExdYSrtId = iSrt.InvType
  LEFT JOIN Orders oSrt WITH(NOLOCK) ON oSrt.OrdId = iSrt.InvOrdId
  LEFT JOIN Delivery d WITH(NOLOCK) ON iSrt.InvId = d.DelInvId
  LEFT JOIN Invoice i WITH(NOLOCK) ON dSrt.DelInvId = i.InvId
  LEFT JOIN Orders o WITH(NOLOCK) ON o.OrdId = i.InvOrdId
WHERE ExdExpId IN(SELECT Id FROM #IdList WITH(NOLOCK)) 

SELECT /*SCHEMA TOP 0 SCHEMA*/ Void, Expedition.*, ExpDocument.*
FROM (SELECT CONVERT(varchar(1), NULL) AS Void) AS Result
  LEFT JOIN #Expedition AS Expedition ON Void IS NULL
  LEFT JOIN #ExpDocument AS ExpDocument ON Expedition.Id = ExpDocument.ExpId
FOR XML AUTO/*SCHEMA, XMLDATA SCHEMA*/

DROP TABLE #ExpDocument
DROP TABLE #Expedition
DROP TABLE #IdList
    ]]></Text>
    <Parameter Name="UserConId" Type="Int">
      <Value Source="Identity" Item="Name" />
      <Value Source="DBNull" />
    </Parameter>
