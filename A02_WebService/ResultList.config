  </Result>

  <Result Name="DocTrDel" Description="Document Transfer - Delivery.">
  <Command Type="Text" Timeout="90">
    <Text><![CDATA[
--DECLARE @UserConId int, @ParamCode varchar(255), @ParamFrom smalldatetime, @ParamTo smalldatetime SELECT @UserConId = 54497, @ParamCode = 'VE20004887', @ParamFrom = null, @ParamTo = null
SET NOCOUNT ON
DECLARE @Sql nvarchar(max), @WsPar varchar(800)
SET @Sql = ''
IF NOT @ParamCode IS NULL SET @Sql = @Sql + ' AND RTRIM(LTRIM(DelCode)) = @ParamCode'
IF NOT @ParamFrom IS NULL SET @Sql = @Sql + ' AND DelDateConf >= @ParamFrom'
IF NOT @ParamTo IS NULL SET @Sql = @Sql + ' AND DelDateConf <= @ParamTo'
IF @Sql = '' SET @Sql = @Sql + ' AND DelDateConf >= CONVERT(smalldatetime, CONVERT(char(10), (GETDATE() - 1), 120))'
SET @Sql = 'SELECT /*SCHEMA TOP 0 SCHEMA*/DelId FROM Delivery WITH(NOLOCK) WHERE DelState = 1 AND DelXSmtId IN (40, 45, 65) AND DelComId = (SELECT TOP 1 ConComId FROM Contact WITH(NOLOCK) WHERE ConId = @UserConId) AND DelInt = 0' + @Sql

CREATE TABLE #IdList(Id int PRIMARY KEY)
INSERT INTO #IdList
EXEC sp_executesql @Sql, N'@UserConId int, @ParamCode varchar(255), @ParamFrom smalldatetime, @ParamTo smalldatetime', @UserConId, @ParamCode, @ParamFrom, @ParamTo

SELECT DelId, LTRIM(RTRIM(DelCode)) AS DelCode, CASE WHEN DelCodeO <> '' THEN DelCodeO END AS DelCodeO, DelZCode, DelType, CASE WHEN DelNoteExt <> '' THEN DelCodeO END AS DelNoteExt,
  DelC, DelDateAcc, DelDateConf, DelDateS, DelDateHand,
  UsdSmt.UsdTabId AS SmtId, CASE WHEN LTRIM(RTRIM(UsdSmt.UsdCode)) <> '' THEN LTRIM(RTRIM(UsdSmt.UsdCode)) END AS SmtCode, UsdSmt.UsdName AS SmtName,
  DemId, CASE WHEN LTRIM(RTRIM(DemCode)) <> '' THEN LTRIM(RTRIM(DemCode)) END AS DemCode, DemName,
  COALESCE(CstId, -ComId) AS CstId,
  COALESCE(CASE WHEN NOT CstId IS NULL THEN CstName END, ComName) AS CstName,
  COALESCE(CASE WHEN NOT CstId IS NULL THEN CstNameAdd END, ComNameAdd) AS CstNameAdd,
  COALESCE(CASE WHEN NOT CstId IS NULL THEN CstNameAdd2 END, ComNameAdd2) AS CstNameAdd2,
  COALESCE(CASE WHEN NOT CstId IS NULL THEN CstStreet END, ComStreet) AS CstStreet,
  COALESCE(CASE WHEN NOT CstId IS NULL THEN CstCity END, ComCity) AS CstCity,
  RTRIM(COALESCE(CASE WHEN NOT CstId IS NULL THEN CstPostCode END, ComPostCode)) AS CstPostCode,
  UsdCou.UsdName AS CstCouName
INTO #ResultDel
FROM Delivery WITH(NOLOCK)
  JOIN Company WITH(NOLOCK) ON DelComId = ComId
  LEFT JOIN ComShipTo WITH(NOLOCK) ON DelCstId = CstId
  LEFT JOIN UsrDes UsdCou WITH(NOLOCK) ON UsdCou.UsdKind = 2 AND UsdCou.UsdTabId = COALESCE(CASE WHEN NOT CstId IS NULL THEN CstXCouId END, ComXCouId)
  LEFT JOIN UsrDes UsdSmt WITH(NOLOCK) ON UsdSmt.UsdKind = 20 AND UsdSmt.UsdTabId = DelXSmtId
  LEFT JOIN DelivMode WITH(NOLOCK) ON DemId = DelDemId
WHERE DelId IN(SELECT Id FROM #IdList WITH(NOLOCK))
--SELECT * FROM #ResultDel

SELECT SopId, SopDelId AS DelId, SopQtyO AS SopQty, StiId,
  StiCode,
  NULLIF(RTRIM(StiCode2), '') AS StiCode2,
  NULLIF(RTRIM(StiPartNo), '') AS StiPartNo,
  NULLIF(RTRIM(StiPartNo2), '') AS StiPartNo2,
  CONVERT(varchar(50), NULL) AS StiEAN,
  CONVERT(varchar(50), NULL) AS StiEAN2,
  StiName,
  CASE WHEN LTRIM(RTRIM(OrdCode)) <> '' THEN LTRIM(RTRIM(OrdCode)) END AS OrdCode, CASE WHEN LTRIM(RTRIM(OrdCodeO)) <> '' THEN LTRIM(RTRIM(OrdCodeO)) END AS OrdCodeO, OriC,
  SopPrcS AS SopPrc, RTRIM(UsdCur.UsdCodeE) AS SopCurCode, SopPrcSCur AS SopPrcCur
INTO #ResultSop
FROM StoOper WITH(NOLOCK)
  LEFT JOIN StoItem WITH(NOLOCK) ON StiId = SopStiId
  LEFT JOIN OrdItem WITH(NOLOCK) ON OriId = SopOriId
  LEFT JOIN Orders WITH(NOLOCK) ON OrdId = OriOrdId
  LEFT JOIN UsrDes UsdCur WITH(NOLOCK) ON UsdCur.UsdKind = 1 AND UsdCur.UsdTabId = SopXSCurId
WHERE SopState = 1 AND SopDelId IN(SELECT Id FROM #IdList WITH(NOLOCK))
IF @@ROWCOUNT > 0
BEGIN
  SET @WsPar = (SELECT TOP 1 TasValue FROM TabSet WITH(NOLOCK) WHERE TasCode = 'WsEAN' AND (TasConId = @UserConId OR TasConId IS NULL) AND TasValue <> '' ORDER BY TasConId DESC)
  IF @WsPar <> ''
  BEGIN
    IF @WsPar LIKE '%#COMID#%' SET @WsPar = REPLACE(@WsPar, '#COMID#', CONVERT(varchar(10), (SELECT TOP 1 ConComId FROM Contact WITH(NOLOCK) WHERE ConId = @UserConId)))
    SELECT @Sql = 'UPDATE #ResultSop SET StiEAN = tEAN.EAN, StiEAN2 = tEAN.EAN2 FROM #ResultSop JOIN (' + @WsPar + ') tEAN ON #ResultSop.StiId = tEAN.Id'
    EXECUTE(@Sql)
  END
END
--SELECT * FROM #ResultSop
SELECT WarId, WarQty, WarSrcId AS DelId, RTRIM(LTRIM(CASE WHEN WarSNTrack = 1 AND WarSerialNo <> '' THEN WarSerialNo END)) AS WarSerialNo, StiId, StiCode,
  dbo.fWarDurHelper('DurDay0AsNull', StiWarDur, WarTim.UsdTabId, WarTim.UsdTagI, NULL, NULL) AS WarDur
INTO #ResultWarI
FROM Warranty WITH(NOLOCK)
  LEFT JOIN StoItem WITH(NOLOCK) ON WarStiId = StiId
  LEFT JOIN UsrDes WarTim WITH(NOLOCK) ON WarXTimId = WarTim.UsdTabId AND WarTim.UsdKind = 4
WHERE WarYSrtId = 68
  AND WarSrcId IN(SELECT Id FROM #IdList WITH(NOLOCK))
  --AND WarSerialNo <> '' --[ZAM 09.02.23 22:50] 267061
SELECT MIN(WarId) AS WarId, SUM(WarQty) WarQty, DelId, WarSerialNo, StiId, StiCode, WarDur INTO #ResultWar FROM #ResultWarI WITH(NOLOCK) GROUP BY DelId, WarSerialNo, StiId, StiCode, WarDur
DROP TABLE #ResultWarI

SELECT /*SCHEMA TOP 0 SCHEMA*/
  1 AS [Tag], NULL AS [Parent], NULL AS [Result!1],
  NULL AS [Delivery!2!Id], NULL AS [Delivery!2!Code], NULL AS [Delivery!2!CodeO], NULL AS [Delivery!2!ZCode], NULL AS [Delivery!2!Type], NULL AS [Delivery!2!NoteExt], NULL AS [Delivery!2!C], NULL AS [Delivery!2!DateAcc], NULL AS [Delivery!2!DateConf], NULL AS [Delivery!2!DateS], NULL AS [Delivery!2!DateHand], NULL AS [Delivery!2!SmtId], NULL AS [Delivery!2!SmtCode], NULL AS [Delivery!2!SmtName], NULL AS [Delivery!2!DemId], NULL AS [Delivery!2!DemCode], NULL AS [Delivery!2!DemName], NULL AS [Delivery!2!CstId], NULL AS [Delivery!2!CstName], NULL AS [Delivery!2!CstNameAdd], NULL AS [Delivery!2!CstNameAdd2], NULL AS [Delivery!2!CstStreet], NULL AS [Delivery!2!CstCity], NULL AS [Delivery!2!CstPostCode], NULL AS [Delivery!2!CstCouName],
  NULL AS [StoOper!3!Id], NULL AS [StoOper!3!DelId], NULL AS [StoOper!3!Qty], NULL AS [StoOper!3!StiId], NULL AS [StoOper!3!StiCode], NULL AS [StoOper!3!StiCode2], NULL AS [StoOper!3!StiPartNo], NULL AS [StoOper!3!StiPartNo2], NULL AS [StoOper!3!StiEAN], NULL AS [StoOper!3!StiEAN2], NULL AS [StoOper!3!StiName], NULL AS [StoOper!3!OrdCode], NULL AS [StoOper!3!OrdCodeO], NULL AS [StoOper!3!OriC], NULL AS [StoOper!3!Prc], NULL AS [StoOper!3!CurCode], NULL AS [StoOper!3!PrcCur],
  NULL AS [Warranty!4!Id], NULL AS [Warranty!4!Qty], NULL AS [Warranty!4!SerialNo], NULL AS [Warranty!4!StiId], NULL AS [Warranty!4!StiCode], NULL AS [Warranty!4!Dur]
UNION ALL
SELECT
  2 AS [Tag], 1 AS [Parent], NULL AS [Result!1],
  DelId AS [Delivery!2!Id], DelCode AS [Delivery!2!Code], DelCodeO AS [Delivery!2!CodeO], DelZCode AS [Delivery!2!ZCode], DelType AS [Delivery!2!Type], DelNoteExt AS [Delivery!2!NoteExt], DelC AS [Delivery!2!C], DelDateAcc AS [Delivery!2!DateAcc], DelDateConf AS [Delivery!2!DateConf], DelDateS AS [Delivery!2!DateS], DelDateHand AS [Delivery!2!DateHand], SmtId AS [Delivery!2!SmtId], SmtCode AS [Delivery!2!SmtCode], SmtName AS [Delivery!2!SmtName], DemId AS [Delivery!2!DemId], DemCode AS [Delivery!2!DemCode], DemName AS [Delivery!2!DemName], CstId AS [Delivery!2!CstId], CstName AS [Delivery!2!CstName], CstNameAdd AS [Delivery!2!CstNameAdd], CstNameAdd2 AS [Delivery!2!CstNameAdd2], CstStreet AS [Delivery!2!CstStreet], CstCity AS [Delivery!2!CstCity], CstPostCode AS [Delivery!2!CstPostCode], CstCouName AS [Delivery!2!CstCouName],
  NULL AS [StoOper!3!Id], NULL AS [StoOper!3!DelId], NULL AS [StoOper!3!Qty], NULL AS [StoOper!3!StiId], NULL AS [StoOper!3!StiCode], NULL AS [StoOper!3!StiCode2], NULL AS [StoOper!3!StiPartNo], NULL AS [StoOper!3!StiPartNo2], NULL AS [StoOper!3!StiEAN], NULL AS [StoOper!3!StiEAN2], NULL AS [StoOper!3!StiName], NULL AS [StoOper!3!OrdCode], NULL AS [StoOper!3!OrdCodeO], NULL AS [StoOper!3!OriC], NULL AS [StoOper!3!Prc], NULL AS [StoOper!3!CurCode], NULL AS [StoOper!3!PrcCur],
  NULL AS [Warranty!4!Id], NULL AS [Warranty!4!Qty], NULL AS [Warranty!4!SerialNo], NULL AS [Warranty!4!StiId], NULL AS [Warranty!4!StiCode], NULL AS [Warranty!4!Dur]
FROM #ResultDel WITH(NOLOCK)
UNION ALL
SELECT
  3 AS [Tag], 2 AS [Parent], NULL AS [Result!1],
  DelId AS [Delivery!2!Id], NULL AS [Delivery!2!Code], NULL AS [Delivery!2!CodeO], NULL AS [Delivery!2!ZCode], NULL AS [Delivery!2!Type], NULL AS [Delivery!2!NoteExt], NULL AS [Delivery!2!C], NULL AS [Delivery!2!DateAcc], NULL AS [Delivery!2!DateConf], NULL AS [Delivery!2!DateS], NULL AS [Delivery!2!DateHand], NULL AS [Delivery!2!SmtId], NULL AS [Delivery!2!SmtCode], NULL AS [Delivery!2!SmtName], NULL AS [Delivery!2!DemId], NULL AS [Delivery!2!DemCode], NULL AS [Delivery!2!DemName], NULL AS [Delivery!2!CstId], NULL AS [Delivery!2!CstName], NULL AS [Delivery!2!CstNameAdd], NULL AS [Delivery!2!CstNameAdd2], NULL AS [Delivery!2!CstStreet], NULL AS [Delivery!2!CstCity], NULL AS [Delivery!2!CstPostCode], NULL AS [Delivery!2!CstCouName],
  SopId AS [StoOper!3!Id], DelId AS [StoOper!3!DelId], SopQty AS [StoOper!3!Qty], StiId AS [StoOper!3!StiId], StiCode AS [StoOper!3!StiCode], StiCode2 AS [StoOper!3!StiCode2], StiPartNo AS [StoOper!3!StiPartNo], StiPartNo2 AS [StoOper!3!StiPartNo2], StiEAN AS [StoOper!3!StiEAN], StiEAN2 AS [StoOper!3!StiEAN2], StiName AS [StoOper!3!StiName], OrdCode AS [StoOper!3!OrdCode], OrdCodeO AS [StoOper!3!OrdCodeO], OriC AS [StoOper!3!OriC], SopPrc AS [StoOper!3!Prc], SopCurCode AS [StoOper!3!CurCode], SopPrcCur AS [StoOper!3!PrcCur],
  NULL AS [Warranty!4!Id], NULL AS [Warranty!4!Qty], NULL AS [Warranty!4!SerialNo], NULL AS [Warranty!4!StiId], NULL AS [Warranty!4!StiCode], NULL AS [Warranty!4!Dur]
FROM #ResultSop WITH(NOLOCK)
UNION ALL
SELECT
  4 AS [Tag], 2 AS [Parent], NULL AS [Result!1],
  DelId AS [Delivery!2!Id], NULL AS [Delivery!2!Code], NULL AS [Delivery!2!CodeO], NULL AS [Delivery!2!ZCode], NULL AS [Delivery!2!Type], NULL AS [Delivery!2!NoteExt], NULL AS [Delivery!2!C], NULL AS [Delivery!2!DateAcc], NULL AS [Delivery!2!DateConf], NULL AS [Delivery!2!DateS], NULL AS [Delivery!2!DateHand], NULL AS [Delivery!2!SmtId], NULL AS [Delivery!2!SmtCode], NULL AS [Delivery!2!SmtName], NULL AS [Delivery!2!DemId], NULL AS [Delivery!2!DemCode], NULL AS [Delivery!2!DemName], NULL AS [Delivery!2!CstId], NULL AS [Delivery!2!CstName], NULL AS [Delivery!2!CstNameAdd], NULL AS [Delivery!2!CstNameAdd2], NULL AS [Delivery!2!CstStreet], NULL AS [Delivery!2!CstCity], NULL AS [Delivery!2!CstPostCode], NULL AS [Delivery!2!CstCouName],
  NULL AS [StoOper!3!Id], NULL AS [StoOper!3!DelId], NULL AS [StoOper!3!Qty], NULL AS [StoOper!3!StiId], NULL AS [StoOper!3!StiCode], NULL AS [StoOper!3!StiCode2], NULL AS [StoOper!3!StiPartNo], NULL AS [StoOper!3!StiPartNo2], NULL AS [StoOper!3!StiEAN], NULL AS [StoOper!3!StiEAN2], NULL AS [StoOper!3!StiName], NULL AS [StoOper!3!OrdCode], NULL AS [StoOper!3!OrdCodeO], NULL AS [StoOper!3!OriC], NULL AS [StoOper!3!Prc], NULL AS [StoOper!3!CurCode], NULL AS [StoOper!3!PrcCur],
  WarId AS [Warranty!4!Id], WarQty AS [Warranty!4!Qty], WarSerialNo AS [Warranty!4!SerialNo], StiId AS [Warranty!4!StiId], StiCode AS [Warranty!4!StiCode], WarDur AS [Warranty!4!Dur]
FROM #ResultWar WITH(NOLOCK)
ORDER BY [Delivery!2!Id], [Tag], [StoOper!3!Id], [Warranty!4!Id]
FOR XML EXPLICIT/*SCHEMA, XMLDATA SCHEMA*/

DROP TABLE #ResultDel
DROP TABLE #ResultWar
DROP TABLE #ResultSop
DROP TABLE #IdList
    ]]></Text>
    <Parameter Name="UserConId" Type="Int">
