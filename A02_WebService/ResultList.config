    <Parameter Name="UserConId" Type="Int">
      <Value Source="Identity" Item="Name" />
      <Value Source="DBNull" />
    </Parameter>
    <Parameter Name="ParamCode" Type="VarChar">
      <Value Source="RunTime" />
      <Value Source="DBNull" />
    </Parameter>
    <Parameter Name="ParamFrom" Type="SmallDateTime">
      <Value Source="RunTime" />
      <Value Source="DBNull" />
    </Parameter>
    <Parameter Name="ParamTo" Type="SmallDateTime">
      <Value Source="RunTime" />
